---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/services', label: 'Services' },
  { href: '/who-its-for', label: "Who It's For" },
  { href: '/how-it-works', label: 'How It Works' },
  { href: '/insights', label: 'Insights' },
  { href: '/about', label: 'About' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 px-4 pt-5 pointer-events-none">
  <nav
    class="pointer-events-auto max-w-6xl mx-auto bg-white rounded-[42px] flex items-center gap-6 px-5 pr-4 py-3 shadow-[0_18px_50px_rgba(8,14,30,0.22)]"
    aria-label="Main navigation"
  >
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 shrink-0 group" aria-label="Democratic AI Consulting — Home">
      <img
        src="/brand/logos/democratic-ai_horizontal_primary.svg"
        alt="Democratic AI Consulting"
        class="h-7 w-auto"
        width="140"
        height="28"
      />
    </a>

    <!-- Desktop links -->
    <div class="hidden md:flex items-center gap-6 ml-2">
      {links.map((link) => (
        <a
          href={link.href}
          class={`text-[14.5px] font-medium transition-colors duration-150 ${
            currentPath === link.href || currentPath.startsWith(link.href + '/')
              ? 'text-coral'
              : 'text-ink hover:text-coral'
          }`}
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="flex-1" />

    <!-- CTA -->
    <a
      href="/contact"
      class="shrink-0 hidden sm:flex items-center gap-1.5 bg-ink text-white rounded-[30px] px-5 py-2.5 text-[14.5px] font-semibold hover:bg-[#1a2740] active:scale-95 transition-all duration-150 focus-visible:ring-2 focus-visible:ring-coral focus-visible:ring-offset-2"
    >
      Book an Audit <span class="text-coral text-lg leading-none">&rsaquo;</span>
    </a>

    <!-- Mobile hamburger -->
    <button
      id="menu-toggle"
      class="sm:hidden flex flex-col gap-1.5 p-2 rounded-lg hover:bg-paper transition-colors"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="block w-5 h-0.5 bg-ink rounded transition-transform duration-200" id="bar1"></span>
      <span class="block w-5 h-0.5 bg-ink rounded transition-opacity duration-200" id="bar2"></span>
      <span class="block w-5 h-0.5 bg-ink rounded transition-transform duration-200" id="bar3"></span>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="pointer-events-auto hidden mt-2 max-w-6xl mx-auto bg-white rounded-[24px] shadow-[0_18px_50px_rgba(8,14,30,0.22)] overflow-hidden"
    aria-hidden="true"
  >
    <div class="px-6 py-5 flex flex-col gap-4">
      {links.map((link) => (
        <a
          href={link.href}
          class="text-[16px] font-medium text-ink hover:text-coral transition-colors duration-150 py-1"
        >
          {link.label}
        </a>
      ))}
      <a
        href="/contact"
        class="mt-2 text-center bg-coral text-white rounded-[30px] px-5 py-3 text-[15px] font-semibold hover:bg-coral-lt active:scale-95 transition-all duration-150"
      >
        Book a Leverage Audit
      </a>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const bar1 = document.getElementById('bar1');
  const bar2 = document.getElementById('bar2');
  const bar3 = document.getElementById('bar3');

  let open = false;

  toggle?.addEventListener('click', () => {
    open = !open;
    menu?.classList.toggle('hidden', !open);
    toggle.setAttribute('aria-expanded', String(open));
    menu?.setAttribute('aria-hidden', String(!open));

    if (open) {
      bar1?.style.setProperty('transform', 'translateY(8px) rotate(45deg)');
      bar2?.style.setProperty('opacity', '0');
      bar3?.style.setProperty('transform', 'translateY(-8px) rotate(-45deg)');
    } else {
      bar1?.style.removeProperty('transform');
      bar2?.style.removeProperty('opacity');
      bar3?.style.removeProperty('transform');
    }
  });

  // Close on link click
  menu?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      open = false;
      menu.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
    });
  });
</script>
